{
  "name": "enhanced-ms",
  "version": "5.0.0",
  "description": "Convert milliseconds to human-readable duration strings and vice versa",
  "keywords": [
    "duration",
    "format",
    "humanize",
    "ms",
    "parse",
    "pretty",
    "print",
    "readable",
    "time"
  ],
  "homepage": "https://github.com/k0d13/enhanced-ms#readme",
  "bugs": {
    "url": "https://github.com/k0d13/enhanced-ms/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k0d13/enhanced-ms.git"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./locales/*": {
      "types": "./dist/locales/*.d.mts",
      "default": "./dist/locales/*.mjs"
    }
  },
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "vitest --run",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "change": "changeset",
    "release:version": "changeset version && oxfmt package.json",
    "release:snapshot:version": "changeset version --snapshot beta && oxfmt package.json",
    "release:publish": "pnpm build && changeset publish",
    "release:snapshot:publish": "pnpm build && changeset publish --tag beta --no-git-tag"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@changesets/config": "^3.1.3",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0"
}
