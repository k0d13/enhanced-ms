{
  "name": "enhanced-ms",
  "version": "4.3.0",
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./locales/*": {
      "types": "./dist/locales/*.d.mts",
      "default": "./dist/locales/*.mjs"
    }
  },
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "vitest --run",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "prepare": "husky",
    "change": "changeset",
    "release:version": "changeset version && biome format package.json --write",
    "release:snapshot:version": "changeset version --snapshot beta && biome format package.json --write",
    "release:publish": "pnpm build && changeset publish",
    "release:snapshot:publish": "pnpm build && changeset publish --tag beta --no-git-tag"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@changesets/config": "^3.1.3",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0"
}
